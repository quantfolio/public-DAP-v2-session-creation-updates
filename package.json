{
  "name": "performativ-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite-node --watch src/index.ts",
    "build": "vite build",
    "start": "node dist/index.js",
    "gen": "openapi-ts",
    "typecheck": "tsc --noEmit",
    "web": "pnpm -C web dev",
    "web:install": "pnpm -C web install",
    "web:build": "pnpm -C web build"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.98.2",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vite-node": "^3.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
