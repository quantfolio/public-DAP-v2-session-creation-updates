# DeepAlpha API credentials (OAuth2 client-credentials grant).
# Copy to `.env` and fill in real values — `.env` is gitignored.
dap_uri=https://api.test.deepalpha.dev
dap_client_id=your-client-id
dap_client_secret=your-client-secret

# Optional: a default advice session id for direct API calls / smoke test.
# dap_session_id=
